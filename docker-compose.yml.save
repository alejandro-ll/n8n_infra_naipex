version: '3.8'
services:
  n8n:
    image: n8nio/n8n:latest
    container_name: naipex-n8n
    restart: unless-stopped
    environment:
      - N8N_HOST=workflows.nxops.cloud
      - N8N_PROTOCOL=https
      - N8N_PORT=5678
      - WEBHOOK_URL=https://workflows.nxops.cloud/
      - N8N_SECURE_COOKIE=true
      - EXECUTIONS_DATA_PRUNE=true
      - EXECUTIONS_DATA_MAX_AGE=168
      - N8N_PAYLOAD_SIZE_MAX=64
      - NODES_EXCLUDE=[]
    volumes:
      - ./data/n8n:/home/node/.n8n
      - /home/operador/proyectos/robot_kpi:/home/operador/proyectos/robot_kpi
    extra_hosts:
      - "host.docker.internal:host-gateway"
    mem_limit: 2g
    cpus: 2
    networks:
      - internal

  nginx:
    image: nginx:alpine
    container_name: naipex-nginx
    restart: unless-stopped
    ports:
      - "443:443"
      - "80:80"
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - /opt/certs:/etc/nginx/certs:ro
    depends_on:
      - n8n
    networks:
      - internal

networks:
  internal:
